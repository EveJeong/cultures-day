rules_version = '2';

// 바딧불이 야호 — 사내 1일 이벤트용 규칙.
// 접근 제어는 앱 레벨(Remote Config open/close + 운영 PIN)에서 수행한다.
// 행사 종료 후에는 write를 false로 바꿔 데이터를 동결한다.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if true; // 이벤트 기간 한정
    }
  }
}
